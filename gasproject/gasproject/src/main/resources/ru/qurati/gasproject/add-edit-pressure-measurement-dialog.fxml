<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane alignment="center" hgap="10" prefWidth="450.0" vgap="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.qurati.gasproject.controller.pressuremeasurement.AddEditPressureMeasurementDialog">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="Сегмент трубы:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <ComboBox fx:id="segmentComboBox" prefWidth="280.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Компрессорная станция:" GridPane.rowIndex="1" />
        <ComboBox fx:id="stationComboBox" prefWidth="280.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Давление (атм):" GridPane.rowIndex="2" />
        <TextField fx:id="pressureField" prefWidth="280.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="Температура (°C):" GridPane.rowIndex="3" />
        <TextField fx:id="temperatureField" prefWidth="280.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Button fx:id="okButton" mnemonicParsing="false" prefWidth="100.0" text="OK" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="6" />
        <Label fx:id="errorLabel" textFill="red" GridPane.columnSpan="2" GridPane.rowIndex="5" />
    </children>
    <columnConstraints>
        <ColumnConstraints />
        <ColumnConstraints />
        <ColumnConstraints />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
    </rowConstraints>
</GridPane>